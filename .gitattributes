# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary

# Exclude from git archives
.gitattributes export-ignore
.gitignore export-ignore
.claude-plugin/ export-ignore
.github/ export-ignore
.pre-commit-config.yaml export-ignore
.editorconfig export-ignore
Makefile export-ignore
.github/CONTRIBUTING.md export-ignore
tests/ export-ignore
test*.py export-ignore
.venv/ export-ignore
CODE_QUALITY_REPORT.md export-ignore
QUALITY_IMPROVEMENTS.md export-ignore
TEST_REPORT.md export-ignore
new.md export-ignore
*.egg-info/ export-ignore
