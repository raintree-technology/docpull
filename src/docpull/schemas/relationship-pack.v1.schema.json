{
  "$defs": {
    "CoverageResult": {
      "additionalProperties": true,
      "properties": {
        "acquired_document_count": {
          "default": 0,
          "minimum": 0,
          "title": "Acquired Document Count",
          "type": "integer"
        },
        "candidates": {
          "items": {
            "$ref": "#/$defs/RelationshipCandidate"
          },
          "title": "Candidates",
          "type": "array"
        },
        "coverage_gap": {
          "default": false,
          "title": "Coverage Gap",
          "type": "boolean"
        },
        "failures": {
          "items": {
            "$ref": "#/$defs/WorkflowFailure"
          },
          "title": "Failures",
          "type": "array"
        },
        "input": {
          "additionalProperties": true,
          "title": "Input",
          "type": "object"
        },
        "input_id": {
          "title": "Input Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate_found",
            "acquired_no_candidate",
            "retryable_failure",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/WorkflowWarning"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "input_id",
        "input",
        "status"
      ],
      "title": "CoverageResult",
      "type": "object"
    },
    "EvidenceSpan": {
      "additionalProperties": true,
      "properties": {
        "char_end": {
          "minimum": 0,
          "title": "Char End",
          "type": "integer"
        },
        "char_start": {
          "minimum": 0,
          "title": "Char Start",
          "type": "integer"
        },
        "citation_id": {
          "title": "Citation Id",
          "type": "string"
        },
        "document_id": {
          "title": "Document Id",
          "type": "string"
        },
        "document_version": {
          "title": "Document Version",
          "type": "string"
        },
        "exact_text": {
          "title": "Exact Text",
          "type": "string"
        },
        "exact_text_sha256": {
          "title": "Exact Text Sha256",
          "type": "string"
        },
        "record_citation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Citation Id"
        },
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "citation_id",
        "document_id",
        "document_version",
        "url",
        "char_start",
        "char_end",
        "exact_text",
        "exact_text_sha256"
      ],
      "title": "EvidenceSpan",
      "type": "object"
    },
    "RelationshipCandidate": {
      "additionalProperties": true,
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceSpan"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "object": {
          "$ref": "#/$defs/RelationshipEntity"
        },
        "predicate": {
          "enum": [
            "owned_by",
            "operated_by",
            "acquired_by",
            "franchised_by",
            "invested_in"
          ],
          "title": "Predicate",
          "type": "string"
        },
        "status": {
          "const": "observation",
          "default": "observation",
          "title": "Status",
          "type": "string"
        },
        "subject": {
          "$ref": "#/$defs/RelationshipEntity"
        },
        "type": {
          "const": "relationship_candidate",
          "default": "relationship_candidate",
          "title": "Type",
          "type": "string"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "subject",
        "predicate",
        "object",
        "confidence",
        "evidence"
      ],
      "title": "RelationshipCandidate",
      "type": "object"
    },
    "RelationshipEntity": {
      "additionalProperties": true,
      "properties": {
        "location_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location Scope"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "RelationshipEntity",
      "type": "object"
    },
    "WorkflowFailure": {
      "additionalProperties": true,
      "properties": {
        "attempts": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attempts"
        },
        "code": {
          "default": "workflow_error",
          "title": "Code",
          "type": "string"
        },
        "http_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Status"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "retry_after_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After Seconds"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        },
        "stage": {
          "default": "workflow",
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "WorkflowFailure",
      "type": "object"
    },
    "WorkflowWarning": {
      "additionalProperties": true,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "WorkflowWarning",
      "type": "object"
    }
  },
  "$id": "https://docpull.dev/schemas/relationship-pack.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "candidates": {
      "items": {
        "$ref": "#/$defs/RelationshipCandidate"
      },
      "title": "Candidates",
      "type": "array"
    },
    "contract_version": {
      "const": "relationship.pack.v1",
      "default": "relationship.pack.v1",
      "title": "Contract Version",
      "type": "string"
    },
    "coverage": {
      "items": {
        "$ref": "#/$defs/CoverageResult"
      },
      "title": "Coverage",
      "type": "array"
    },
    "pack_identity": {
      "additionalProperties": true,
      "title": "Pack Identity",
      "type": "object"
    },
    "run_identity": {
      "additionalProperties": true,
      "title": "Run Identity",
      "type": "object"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "summary": {
      "additionalProperties": true,
      "title": "Summary",
      "type": "object"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/WorkflowWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "pack_identity",
    "run_identity",
    "coverage"
  ],
  "title": "RelationshipPack",
  "type": "object"
}
